# GFS 预报时长（小时）
GFS_FORECAST_HOURS=24

# GFS 数据发布延迟（小时），一般 4 小时后可获取最新周期
GFS_LATENCY_HOURS=4

# 调度模式下处理的变量列表（逗号分隔）
# 可选: wind, temp, rh, spfh, dpt, hgt, tcdc, lcdc, mcdc, hcdc, vis, apcp, prate, pres, prmsl, gust
# 等压面变量固定处理 850 hPa；单层变量按各自层级下载
# SCHEDULE_VARIABLES=wind

# 并行工作进程数
NUM_WORKERS=8

# 瓦片输出到宿主机的路径（Docker 部署时用于映射瓦片目录到宿主机）
TILES_HOST_PATH=""

# 地图数据根目录（Docker 部署时设为 /app，本地开发无需配置）
# MAP_DATA_ROOT=/app
